<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="760.0" prefWidth="940.0" spacing="18.0" style="-fx-background-color: #f4f7fb; -fx-padding: 20px;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bluemoon.controllers.ThongBaoController">
    <Label text="Quản lý thông báo" textFill="#243447">
        <font>
            <Font name="System Bold" size="22.0" />
        </font>
    </Label>
    <Label text="Quản lý các thông báo và tài liệu tiện ích trong hệ thống." style="-fx-font-size: 14px; -fx-text-fill: #6b7a8f;" />

    <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: transparent;">
        <tabs>
            <Tab text="Thêm thông báo">
                <VBox spacing="16.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #dfe7f1; -fx-border-radius: 14; -fx-effect: dropshadow(gaussian, rgba(35, 52, 72, 0.08), 14, 0, 0, 6);">
                    <padding>
                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                    </padding>
                    <GridPane hgap="18.0" vgap="14.0">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120.0" halignment="RIGHT" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="260.0" />
                            <ColumnConstraints minWidth="120.0" halignment="RIGHT" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="260.0" />
                        </columnConstraints>

                        <Label text="Tên thông báo" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="txtTitle" style="-fx-background-radius: 8; -fx-padding: 8 10;" promptText="Nhập tên thông báo" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.columnSpan="3" />

                        <Label text="File thông báo" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <HBox spacing="12.0" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="3">
                            <Button fx:id="btnChooseFile" mnemonicParsing="false" onAction="#handleChooseFile" text="Chọn file" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8;" />
                            <Label fx:id="lblSelectedFile" text="Chưa chọn file" style="-fx-text-fill: #6b7a8f;" />
                        </HBox>

                        <Label text="Ngày ban hành" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <DatePicker fx:id="dpNgayBanHanh" style="-fx-background-radius: 8;" GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <Label text="Trạng thái" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.columnIndex="2" GridPane.rowIndex="2" />
                        <ComboBox fx:id="cbStatus" style="-fx-background-radius: 8;" GridPane.columnIndex="3" GridPane.rowIndex="2" />
                    </GridPane>

                    <HBox alignment="CENTER_RIGHT" spacing="14.0" style="-fx-padding: 4 0 0 0;">
                        <Button fx:id="btnResetForm" mnemonicParsing="false" onAction="#handleResetForm" text="Reset" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8;" />
                        <Button fx:id="btnAddNotification" mnemonicParsing="false" onAction="#handleAddNotification" text="Thêm" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8;" />
                    </HBox>
                </VBox>
            </Tab>
            <Tab text="Tìm kiếm">
                <VBox spacing="16.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #dfe7f1; -fx-border-radius: 14; -fx-effect: dropshadow(gaussian, rgba(35, 52, 72, 0.08), 14, 0, 0, 6);">
                    <padding>
                        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
                    </padding>
                    <GridPane hgap="18.0" vgap="14.0">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120.0" halignment="RIGHT" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="260.0" />
                            <ColumnConstraints minWidth="120.0" halignment="RIGHT" />
                            <ColumnConstraints hgrow="ALWAYS" minWidth="260.0" />
                        </columnConstraints>

                        <Label text="Tên thông báo" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="txtSearchTitle" style="-fx-background-radius: 8; -fx-padding: 8 10;" promptText="Nhập tên thông báo" GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <Label text="Ngày ban hành" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                        <DatePicker fx:id="dpSearchDate" style="-fx-background-radius: 8;" GridPane.columnIndex="3" GridPane.rowIndex="0" />

                        <Label text="Trạng thái" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <ComboBox fx:id="cbSearchStatus" style="-fx-background-radius: 8;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    </GridPane>
                    <HBox alignment="CENTER_RIGHT" spacing="14.0" style="-fx-padding: 4 0 0 0;">
                        <Button fx:id="btnResetSearch" mnemonicParsing="false" onAction="#handleResetSearch" text="Reset" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8;" />
                        <Button fx:id="btnSearchNotification" mnemonicParsing="false" onAction="#handleSearchNotification" text="Tìm kiếm" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8;" />
                    </HBox>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>

    <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 14; -fx-border-color: #dfe7f1; -fx-border-radius: 14; -fx-effect: dropshadow(gaussian, rgba(35, 52, 72, 0.10), 14, 0, 0, 6);" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="16.0" right="16.0" bottom="16.0" left="16.0" />
        </padding>
        <Label text="Danh sách thông báo" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #243447;" />
        <TableView fx:id="tableThongBao" VBox.vgrow="ALWAYS" style="-fx-background-radius: 10; -fx-border-color: #dfe7f1; -fx-border-radius: 10;">
            <columns>
                <TableColumn fx:id="colStt" prefWidth="60.0" text="STT" />
                <TableColumn fx:id="colTitle" prefWidth="240.0" text="Tên thông báo" />
                <TableColumn fx:id="colFile" prefWidth="220.0" text="File đính kèm" />
                <TableColumn fx:id="colNgayBanHanh" prefWidth="140.0" text="Ngày ban hành" />
                <TableColumn fx:id="colStatus" prefWidth="130.0" text="Trạng thái" />
                <TableColumn fx:id="colActions" prefWidth="140.0" text="Hành động" />
            </columns>
        </TableView>
    </VBox>
</VBox>
