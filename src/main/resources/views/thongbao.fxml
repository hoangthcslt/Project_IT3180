<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="650.0" prefWidth="950.0" spacing="15.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bluemoon.controllers.ThongBaoController">
   <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
   <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="QUẢN LÝ THÔNG BÁO" />
   <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
      <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
      <HBox alignment="CENTER_LEFT" spacing="8.0">
         <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Danh sách thông báo" />
         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="btnSearchNotification" onAction="#handleShowSearchDialog" text="Tìm kiếm" />
         <Button fx:id="btnAddNotification" onAction="#handleShowAddDialog" text="+ Thêm" />
         <Button fx:id="btnExportExcel" onAction="#handleExportExcel" text="Xuất Excel" />
         <Button fx:id="btnResetSearch" onAction="#handleResetSearch" text="Đặt lại" />
      </HBox>
      <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" pannable="true" style="-fx-background-color: transparent;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
         <content>
            <TableView fx:id="tableThongBao" prefHeight="560.0" style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 6;">
               <columns>
                  <TableColumn fx:id="colStt" minWidth="45.0" prefWidth="55.0" text="STT" />
                  <TableColumn fx:id="colTitle" minWidth="180.0" prefWidth="240.0" text="Tên thông báo" />
                  <TableColumn fx:id="colFile" minWidth="140.0" prefWidth="180.0" text="File đính kèm" />
                  <TableColumn fx:id="colNgayBanHanh" minWidth="110.0" prefWidth="125.0" text="Ngày ban hành" />
                  <TableColumn fx:id="colGroups" minWidth="130.0" prefWidth="160.0" text="Nhóm nhận" />
                  <TableColumn fx:id="colStatus" minWidth="100.0" prefWidth="120.0" text="Trạng thái" />
                  <TableColumn fx:id="colActions" minWidth="120.0" prefWidth="135.0" text="Hành động" />
               </columns>
            </TableView>
         </content>
      </ScrollPane>
   </VBox>
</VBox>
