<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane style="-fx-background-color: #f4f7fb;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bluemoon.controllers.PermissionController">
    <top>
        <VBox spacing="6.0" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="18.0" left="24.0" right="24.0" top="24.0" />
            </padding>
            <Label text="Phân quyền" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #243447;" />
            <Label text="Quản lý nhóm người dùng, phân quyền chức năng và gán user vào nhóm." style="-fx-font-size: 14px; -fx-text-fill: #6b7a8f;" />
        </VBox>
    </top>
    <center>
        <TabPane tabClosingPolicy="UNAVAILABLE" style="-fx-background-color: transparent;">
            <tabs>
                <Tab text="Nhóm người dùng">
                    <VBox spacing="14.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(35, 52, 72, 0.12), 14, 0, 0, 5);">
                        <padding>
                            <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
                        </padding>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="Tên nhóm" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                            <TextField fx:id="txtSearchGroup" promptText="Nhập tên nhóm" HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleSearchGroup" text="🔎 Tìm kiếm" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8;" />
                            <Button onAction="#handleAddGroup" text="+ Thêm mới" style="-fx-background-color: #2f80ed; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8;" />
                        </HBox>
                        <TableView fx:id="tblGroups" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colGroupStt" prefWidth="55.0" text="STT" />
                                <TableColumn fx:id="colGroupName" prefWidth="170.0" text="Tên nhóm" />
                                <TableColumn fx:id="colGroupDesc" prefWidth="300.0" text="Mô tả" />
                                <TableColumn fx:id="colPermission" prefWidth="95.0" text="Phân quyền" />
                                <TableColumn fx:id="colGroupAction" prefWidth="140.0" text="Hành động" />
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>
                <Tab text="Quản trị nhóm người dùng">
                    <VBox spacing="14.0" style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(35, 52, 72, 0.12), 14, 0, 0, 5);">
                        <padding>
                            <Insets bottom="18.0" left="18.0" right="18.0" top="18.0" />
                        </padding>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label text="Tìm kiếm" style="-fx-font-weight: bold; -fx-text-fill: #2c3e50;" />
                            <TextField fx:id="txtSearchUser" promptText="Username hoặc vai trò" HBox.hgrow="ALWAYS" />
                            <Button onAction="#handleSearchUser" text="🔎 Tìm kiếm" style="-fx-background-color: #34495e; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8;" />
                            <Button onAction="#handleAddUser" text="+ Thêm" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8;" />
                            <Button onAction="#handleAssignUser" text="Sửa user" style="-fx-background-color: #2f80ed; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8;" />
                            <Button onAction="#handleExportUserExcel" text="📥 Xuất Excel" style="-fx-background-color: #16a085; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 9 16; -fx-background-radius: 8;" />
                        </HBox>
                        <TableView fx:id="tblUserGroups" VBox.vgrow="ALWAYS">
                            <columnResizePolicy>
                                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                            </columnResizePolicy>
                            <columns>
                                <TableColumn fx:id="colUserStt" prefWidth="55.0" text="STT" />
                                <TableColumn fx:id="colUsername" prefWidth="190.0" text="Username" />
                                <TableColumn fx:id="colUserGroup" prefWidth="260.0" text="Nhóm" />
                                <TableColumn fx:id="colUserRole" prefWidth="140.0" text="Vai trò" />
                                <TableColumn fx:id="colUserAction" prefWidth="110.0" text="Hành động" />
                            </columns>
                        </TableView>
                    </VBox>
                </Tab>
            </tabs>
        </TabPane>
    </center>
    <padding>
        <Insets bottom="24.0" left="24.0" right="24.0" />
    </padding>
</BorderPane>
