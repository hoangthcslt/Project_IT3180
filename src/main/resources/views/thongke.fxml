<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bluemoon.controllers.ThongKeController" spacing="15" style="-fx-padding: 20; -fx-background-color: #f4f7fb;" VBox.vgrow="ALWAYS">
    <!-- Header Title and Export Excel Button -->
    <HBox spacing="10" alignment="CENTER_LEFT">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Thống Kê Hệ Thống" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            <Label text="Báo cáo chi tiết về dân cư, căn hộ, công nợ và doanh thu" style="-fx-font-size: 13px; -fx-text-fill: #7f8c8d;"/>
        </VBox>
        <Button text="Xuất Báo Cáo Excel" fx:id="btnXuatExcel" onAction="#handleXuatExcel" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10px 18px; -fx-background-radius: 6; -fx-cursor: hand;"/>
    </HBox>
    
    <!-- KPI Cards Row -->
    <HBox spacing="15" alignment="CENTER">
        <!-- Card 1 -->
        <VBox spacing="5" prefWidth="180" style="-fx-background-color: #ebf5fb; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="👥" style="-fx-font-size: 20px;"/>
                <Label text="Tổng cư dân" style="-fx-font-size: 13px; -fx-text-fill: #2980b9; -fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="lblTongCuDan" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </VBox>
        
        <!-- Card 2 -->
        <VBox spacing="5" prefWidth="180" style="-fx-background-color: #e8f8f5; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="🏢" style="-fx-font-size: 20px;"/>
                <Label text="Tổng căn hộ" style="-fx-font-size: 13px; -fx-text-fill: #16a085; -fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="lblTongCanHo" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </VBox>
        
        <!-- Card 3 -->
        <VBox spacing="5" prefWidth="180" style="-fx-background-color: #fef9e7; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="💰" style="-fx-font-size: 20px;"/>
                <Label text="Tổng doanh thu" style="-fx-font-size: 13px; -fx-text-fill: #d35400; -fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="lblTongDoanhThu" text="0 VND" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </VBox>
        
        <!-- Card 4 -->
        <VBox spacing="5" prefWidth="180" style="-fx-background-color: #fdedec; -fx-background-radius: 10; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="⚠️" style="-fx-font-size: 20px;"/>
                <Label text="Tổng nợ chưa nộp" style="-fx-font-size: 13px; -fx-text-fill: #c0392b; -fx-font-weight: bold;"/>
            </HBox>
            <Label fx:id="lblTongNo" text="0 VND" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </VBox>
    </HBox>
    
    <!-- TabPane with Detailed Statistical Charts -->
    <TabPane fx:id="tabPane" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #dfe7f1; -fx-border-radius: 8; -fx-padding: 10;">
        <tabs>
            <!-- TAB 1: THỐNG KÊ DÂN CƯ -->
            <Tab text="Thống kê Dân cư">
                <HBox spacing="20" alignment="CENTER" style="-fx-padding: 10;">
                    <!-- PieChart for Gender Stats -->
                    <VBox spacing="10" alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: #fcfcfc; -fx-padding: 10; -fx-border-color: #f0f0f0; -fx-border-radius: 6;">
                        <Label text="Tỷ lệ cư dân theo giới tính" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                        <PieChart fx:id="chartGioiTinh" legendSide="BOTTOM" VBox.vgrow="ALWAYS" prefHeight="250" />
                    </VBox>
                    <!-- BarChart for Residency Status -->
                    <VBox spacing="10" alignment="CENTER" HBox.hgrow="ALWAYS" style="-fx-background-color: #fcfcfc; -fx-padding: 10; -fx-border-color: #f0f0f0; -fx-border-radius: 6;">
                        <Label text="Số lượng cư dân theo trạng thái cư trú" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                        <BarChart fx:id="chartTrangThai" legendVisible="false" VBox.vgrow="ALWAYS" prefHeight="250">
                            <xAxis>
                                <CategoryAxis label="Trạng thái cư trú" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Số người" tickUnit="1.0" minorTickCount="0" />
                            </yAxis>
                        </BarChart>
                    </VBox>
                </HBox>
            </Tab>
            
            <!-- TAB 2: DOANH THU & CÔNG NỢ -->
            <Tab text="Doanh thu &amp; Công nợ">
                <VBox spacing="15" style="-fx-padding: 10;">
                    <!-- StackedBarChart for Paid vs Unpaid per Fee -->
                    <VBox spacing="10" style="-fx-background-color: #fcfcfc; -fx-padding: 10; -fx-border-color: #f0f0f0; -fx-border-radius: 6;" VBox.vgrow="ALWAYS">
                        <Label text="So sánh Đã nộp và Chưa nộp theo từng khoản thu" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #34495e;"/>
                        <StackedBarChart fx:id="chartNoVaThu" prefHeight="180">
                            <xAxis>
                                <CategoryAxis label="Khoản thu" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Số tiền (VND)" />
                            </yAxis>
                        </StackedBarChart>
                    </VBox>
                    
                    <!-- AreaChart for Revenue trend over time -->
                    <VBox spacing="10" style="-fx-background-color: #fcfcfc; -fx-padding: 10; -fx-border-color: #f0f0f0; -fx-border-radius: 6;" VBox.vgrow="ALWAYS">
                        <HBox spacing="15" alignment="CENTER_LEFT">
                            <Label text="Xu hướng doanh thu theo thời gian" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #34495e;" HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS" />
                            <Label text="Xem theo:" style="-fx-font-size: 12px;"/>
                            <ComboBox fx:id="comboKieuThoiGian" prefWidth="120" style="-fx-font-size: 12px;" />
                            <Label text="Năm:" style="-fx-font-size: 12px;"/>
                            <ComboBox fx:id="comboNamLoc" prefWidth="100" style="-fx-font-size: 12px;" />
                        </HBox>
                        <AreaChart fx:id="chartDoanhThu" prefHeight="180" legendSide="TOP">
                            <xAxis>
                                <CategoryAxis label="Thời gian" />
                            </xAxis>
                            <yAxis>
                                <NumberAxis label="Số tiền (VND)" />
                            </yAxis>
                        </AreaChart>
                    </VBox>
                </VBox>
            </Tab>
        </tabs>
    </TabPane>
</VBox>
