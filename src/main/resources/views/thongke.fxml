<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bluemoon.controllers.ThongKeController" spacing="15" alignment="CENTER" style="-fx-padding: 20;">
    <Label text="Thống Kê Thu Phí" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    
    <HBox spacing="20" alignment="CENTER">
        <BarChart fx:id="barChart" title="Biểu đồ Nợ và Đã Nộp">
            <xAxis>
                <CategoryAxis label="Khoản Thu" />
            </xAxis>
            <yAxis>
                <NumberAxis label="Số Tiền (VND)" />
            </yAxis>
        </BarChart>
        
        <PieChart fx:id="pieChart" title="Tỷ lệ thu phí"/>
    </HBox>
    
    <Button text="Xuất Excel" fx:id="btnXuatExcel" onAction="#handleXuatExcel" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
</VBox>
