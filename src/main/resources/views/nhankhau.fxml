<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="650.0" prefWidth="950.0" spacing="15.0" style="-fx-background-color: #f8fafc;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bluemoon.controllers.ResidentController">
   <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
   <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #0f172a;" text="QUẢN LÝ NHÂN KHẨU" />
   <VBox spacing="12.0" style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #e2e8f0; -fx-border-radius: 8;" VBox.vgrow="ALWAYS">
      <padding><Insets bottom="15.0" left="15.0" right="15.0" top="15.0" /></padding>
      <HBox alignment="CENTER_LEFT" spacing="8.0">
         <Label style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Danh sách nhân khẩu" />
         <Region HBox.hgrow="ALWAYS" />
         <Button fx:id="btnSearchResident" onAction="#handleShowSearchDialog" text="Tìm kiếm" />
         <Button fx:id="btnAddResident" onAction="#handleShowAddDialog" text="+ Thêm" />
         <Button fx:id="btnExportExcel" onAction="#handleExportExcel" text="Xuất Excel" />
         <Button fx:id="btnResetSearch" onAction="#handleResetSearch" text="Đặt lại" />
      </HBox>
      <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="AS_NEEDED" pannable="true" style="-fx-background-color: transparent;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
         <content>
            <TableView fx:id="tableNhanKhau" prefHeight="560.0" style="-fx-background-color: white; -fx-border-color: #cbd5e1; -fx-border-radius: 6;">
               <columns>
                  <TableColumn fx:id="colId" minWidth="45.0" prefWidth="50.0" text="ID" />
                  <TableColumn fx:id="colHoKhauId" minWidth="80.0" prefWidth="90.0" text="ID Hộ Khẩu" />
                  <TableColumn fx:id="colHoTen" minWidth="150.0" prefWidth="190.0" text="Họ Tên" />
                  <TableColumn fx:id="colCccd" minWidth="115.0" prefWidth="125.0" text="CCCD" />
                  <TableColumn fx:id="colSoDienThoai" minWidth="100.0" prefWidth="115.0" text="SĐT" />
                  <TableColumn fx:id="colNgaySinh" minWidth="100.0" prefWidth="110.0" text="Ngày Sinh" />
                  <TableColumn fx:id="colGioiTinh" minWidth="75.0" prefWidth="85.0" text="Giới Tính" />
                  <TableColumn fx:id="colQuanHe" minWidth="90.0" prefWidth="100.0" text="Quan Hệ" />
                  <TableColumn fx:id="colTrangThai" minWidth="95.0" prefWidth="110.0" text="Trạng Thái" />
                  <TableColumn fx:id="colHoatDong" minWidth="120.0" prefWidth="135.0" text="Hoạt Động" />
               </columns>
            </TableView>
         </content>
      </ScrollPane>
   </VBox>
</VBox>
