<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bluemoon.controllers.PaymentController" spacing="10" alignment="CENTER" style="-fx-padding: 20;">
    <Label text="Thanh Toán Phí" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
    
    <GridPane hgap="10" vgap="10" alignment="CENTER">
        <Label text="Mã hộ khẩu:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <HBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="10">
            <TextField fx:id="txtMaHoKhau" promptText="Nhập mã hộ khẩu..."/>
            <Button text="Tìm" onAction="#handleTimHoKhau"/>
        </HBox>
        
        <Label text="Tên chủ hộ:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <Label fx:id="lblTenChuHo" text="---" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        
        <Label text="Chọn khoản thu:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="cbKhoanThu" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
        
        <Label text="Nợ hiện tại (VND):" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <Label fx:id="lblNoHienTai" text="0" style="-fx-text-fill: red; -fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
        
        <Label text="Số tiền nộp:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="txtSoTienNop" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
        
        <Label text="Hình thức nộp:" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <ComboBox fx:id="cbHinhThuc" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
        
        <Label text="Người nộp:" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <TextField fx:id="txtNguoiNop" GridPane.columnIndex="1" GridPane.rowIndex="6"/>
    </GridPane>
    
    <Button text="Thực hiện thanh toán" fx:id="btnThanhToan" onAction="#handleThanhToan"/>
</VBox>
