<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.bluemoon.controllers.DashboardController">
    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="60.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
            <padding>
                <Insets left="20.0" right="20.0" />
            </padding>
            <Label text="BLUE MOON - QUẢN LÝ CHUNG CƯ" textFill="WHITE">
                <font>
                    <Font name="System Bold" size="18.0" />
                </font>
            </Label>
            <HBox HBox.hgrow="ALWAYS" />
            <Label fx:id="lblWelcome" textFill="WHITE" text="Xin chào!">
                <font>
                    <Font size="14.0" />
                </font>
            </Label>
        </HBox>
    </top>

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="200.0" spacing="10.0" style="-fx-background-color: #34495e;" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="20.0" left="10.0" right="10.0" top="20.0" />
            </padding>
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleHoKhau" text="Hộ khẩu" style="-fx-background-color: #ecf0f1; -fx-font-weight: bold; -fx-padding: 10px;" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleNhanKhau" text="Nhân khẩu" style="-fx-background-color: #ecf0f1; -fx-font-weight: bold; -fx-padding: 10px;" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleKhoanThu" text="Khoản thu" style="-fx-background-color: #ecf0f1; -fx-font-weight: bold; -fx-padding: 10px;" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleNopTien" text="Nộp tiền" style="-fx-background-color: #ecf0f1; -fx-font-weight: bold; -fx-padding: 10px;" />
            <Button maxWidth="Infinity" mnemonicParsing="false" onAction="#handleThongKe" text="Thống kê" style="-fx-background-color: #ecf0f1; -fx-font-weight: bold; -fx-padding: 10px;" />
        </VBox>
    </left>

    <!-- CONTENT AREA -->
    <center>
        <VBox alignment="CENTER" BorderPane.alignment="CENTER" style="-fx-background-color: #ffffff;">
            <Label text="CHÀO MỪNG ĐẾN VỚI HỆ THỐNG QUẢN LÝ" textFill="#7f8c8d">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
            </Label>
            <Label text="Vui lòng chọn chức năng ở thanh công cụ bên trái." textFill="#95a5a6">
                <font>
                    <Font size="14.0" />
                </font>
                <VBox.margin>
                    <Insets top="10.0" />
                </VBox.margin>
            </Label>
        </VBox>
    </center>
</BorderPane>
